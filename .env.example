# Pooled connection string, used by the application at runtime.
DATABASE_URL=

# Direct (non-pooled) connection string, used by Prisma Migrate.
DIRECT_URL=

# "mock" allows simulating successful payments without contacting Stripe.
# "stripe" uses Stripe-hosted Checkout in test mode (see below).
# Mock confirmation is always blocked when NODE_ENV=production.
PAYMENTS_MODE=mock

# Base URL used to build absolute share/redirect links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required only when PAYMENTS_MODE=stripe. USD is the only supported currency;
# Stripe mode fails closed (refuses to process checkouts) if this isn't "usd"
# or if either Stripe variable below is missing.
PAYMENT_CURRENCY=usd

# Stripe test-mode secret key (starts with sk_test_). Server-only — never
# exposed to client code. See README for how to obtain this.
STRIPE_SECRET_KEY=

# Signing secret printed by `stripe listen` (starts with whsec_). Used to
# verify that webhook requests genuinely came from Stripe.
STRIPE_WEBHOOK_SECRET=

# Stripe test-mode publishable key (starts with pk_test_). Safe for client
# code, though this app's hosted-Checkout redirect flow doesn't currently
# read it anywhere.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
